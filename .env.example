FEISHU_APP_ID=cli_xxx
FEISHU_APP_SECRET=xxx
WORKDIR=/root
STATE_DIR=./data

# Path to Claude Code CLI (default: claude in PATH)
CLAUDE_CMD=/root/.local/bin/claude

# Optional model override (e.g. claude-sonnet-4-6, claude-haiku-4-5)
CLAUDE_MODEL=

# Permission mode: default | acceptEdits | auto | plan | dontAsk
# Leave blank to use the approval-card flow (recommended).
CLAUDE_PERMISSION_MODE=

# Enable interactive approval cards for tool use (true/false). Default: true.
# When true, every tool call Claude makes will fire a Feishu card asking for
# approval, sourced from a built-in MCP server.
CLAUDE_APPROVAL_CARDS=true

# Tools to allow without prompting (comma-separated). Recommended for read-only
# noise reduction. Example: Read,Glob,Grep,TodoWrite,WebFetch
CLAUDE_AUTO_APPROVE_TOOLS=Read,Glob,Grep,TodoWrite,TodoRead,WebFetch,WebSearch

# Extra args appended to every claude invocation (space-separated).
CLAUDE_EXTRA_ARGS=

# Hard cap per turn in ms (0 = no cap)
CLAUDE_TURN_TIMEOUT_MS=0

# Optional: lark SDK path if @larksuiteoapi/node-sdk is not in node_modules
LARK_SDK_PATH=
